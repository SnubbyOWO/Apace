@page "/Admin/Users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using Solace.LauncherUI.Data
@using Solace.LauncherUI.Utils
@attribute [Authorize(Policy = Permissions.ViewUsers)]
@rendermode InteractiveServer
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<ApplicationRole> RoleManager
@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext DbContext

<PageTitle>User Management - Apace</PageTitle>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
    <div class="section-title mb-0" style="border-bottom: none; padding-bottom: 0;">
        <img class="nav-icon" src="/images/sign_icon.png" alt="" /> User Management
    </div>

    <div class="input-group" style="max-width: 400px;">
        <span class="input-group-text">⌕</span>
        <input type="text" class="form-control" placeholder="Search username or email..." @bind="_searchTerm"
               @bind:after="ResetAndLoad" />
        @if (!string.IsNullOrEmpty(_searchTerm))
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                ✕
            </button>
        }
    </div>
</div>

@if (_users == null)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!_users.Any())
{
    <div class="alert alert-info text-center py-4">
        No users found matching your criteria.
    </div>
}
else
{
    <div class="d-none d-md-block">
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in _users)
                        {
                            var targetRoles = _userRolesMap.GetValueOrDefault(user.Id) ?? new List<string>();
                            var targetMinPos = GetMinPositionForRoles(targetRoles);
                            var isProtected = targetMinPos <= _userMinPosition && user.Id != _currentUserId;

                            <tr>
                                <td><strong>@user.UserName</strong></td>
                                <td style="color: #9a9ab0;">@user.Email</td>
                                <td>@RenderUserRoles(targetRoles)</td>
                                <td class="text-end">@RenderActions((user, isProtected))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-md-none">
        @foreach (var user in _users)
        {
            var targetRoles = _userRolesMap.GetValueOrDefault(user.Id) ?? new List<string>();
            var targetMinPos = GetMinPositionForRoles(targetRoles);
            var isProtected = targetMinPos <= _userMinPosition && user.Id != _currentUserId;

            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <strong>@user.UserName</strong>
                    </div>
                    <div class="mt-2 small" style="color: #9a9ab0;">@user.Email</div>
                    <div class="mt-2">
                        @RenderUserRoles(targetRoles)
                    </div>
                    <div class="mt-3 d-flex flex-wrap gap-2">
                        @RenderActions((user, isProtected))
                    </div>
                </div>
            </div>
        }
    </div>

    @if (_totalPages > 1)
    {
        <nav aria-label="User navigation" class="mt-4">
            <ul class="pagination justify-content-center" style="display: flex; gap: 6px; list-style: none;">
                <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(_currentPage - 1)">Previous</button>
                </li>

                @for (int i = Math.Max(1, _currentPage - 2); i <= Math.Min(_totalPages, _currentPage + 2); i++)
                {
                    var pageNumber = i;
                    <li class="page-item @(_currentPage == pageNumber ? "active" : "")">
                        <button class="page-link" @onclick="() => ChangePage(pageNumber)">@pageNumber</button>
                    </li>
                }

                <li class="page-item @(_currentPage == _totalPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePage(_currentPage + 1)">Next</button>
                </li>
            </ul>
            <div class="text-center small mt-2" style="color: #9a9ab0;">
                Showing @(_users.Count) of @_totalUsers total users
            </div>
        </nav>
    }
}

@if (_isEditing)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.6); position: fixed; inset: 0; z-index: 1050;">
        <div class="modal-dialog modal-lg" style="margin: 5vh auto;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(_model.IsReadOnly ? "View User Details" : "Edit User")
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => _isEditing = false"></button>
                </div>
                <div class="modal-body" style="padding: 20px;">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
                            <div>⚠ @_errorMessage</div>
                        </div>
                    }

                    @if (_canEditAccountInfo)
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Username</label>
                                <input class="form-control" @bind="_model.UserName" disabled="@_model.IsReadOnly" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" @bind="_model.Email" disabled="@_model.IsReadOnly" />
                            </div>
                        </div>

                        @if (!_model.IsReadOnly)
                        {
                            <div class="mb-4 p-3 alert-light" style="border: 2px solid #3a3a3a;">
                                <label class="form-label fw-bold">Reset Password <span class="text-muted fw-normal">(Leave blank to
                                    keep current)</span></label>
                                    <input type="password" class="form-control" @bind="_model.NewPassword"
                                           placeholder="Enter new password..." />
                                </div>
                            }
                        }

                        @if (_canAssignRoles || _model.IsReadOnly)
                        {
                            <h6 class="mt-3">Role Assignments</h6>
                            <div class="row mt-2">
                                @foreach (var role in _roles.OrderBy(r => r.Position))
                                {
                                    var isAssigned = _modelAssignedRoles.Contains(role.Name!);

                                    // CORE SECURITY RULE: Cannot touch built-in roles or roles with Position <= minroleposofcurrentuser
                                    var canTouchRole = role.Position > _userMinPosition && !role.IsBuiltIn;
                                    var isCheckboxDisabled = _model.IsReadOnly || !canTouchRole || !_canAssignRoles;

                                    <div class="col-md-4 mb-2">
                                        <div class="form-check p-2 @(isAssigned ? "bg-light" : "")"
                                             style="border: 2px solid #3a3a3a; border-left: 4px solid @role.Color !important; @(!isCheckboxDisabled ? "cursor: pointer;" : "opacity: 0.7;")">
                                            <input class="form-check-input ms-1" type="checkbox" checked="@isAssigned"
                                                   disabled="@isCheckboxDisabled" @onchange="@(e => ToggleRole(role.Name!, e.Value))" />
                                            <label class="form-check-label ms-2 @(isAssigned ? "fw-bold" : "text-muted")">
                                                @role.Name
                                                @if (role.IsBuiltIn)
                                                {
                                                    <span class="badge bg-secondary ms-1" style="font-size: 0.6rem;">System</span>
                                                }
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <div class="modal-footer bg-light">
                        <button class="btn btn-secondary" @onclick="() => _isEditing = false">Close</button>
                        @if (!_model.IsReadOnly && (_canEditAccountInfo || _canAssignRoles))
                        {
                            <button class="btn btn-primary" @onclick="SaveUser">Save Changes</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_showDeleteConfirm && _userToDelete != null)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.6); position: fixed; inset: 0; z-index: 1060;">
            <div class="modal-dialog modal-dialog-centered" style="max-width: 480px; margin: 10vh auto;">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" style="color: #e57373;">Confirm Delete</h5>
                        <button class="btn-close" @onclick="CloseDeleteConfirm"></button>
                    </div>
                    <div class="modal-body" style="padding: 20px;">
                        <p>
                            Are you sure you want to delete user
                            <strong>@_userToDelete.UserName</strong>?
                        </p>
                        <p class="text-muted small">This action cannot be undone and will remove all associated data.</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseDeleteConfirm">Cancel</button>
                        <button class="btn btn-danger" @onclick="DeleteConfirmed">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    }

@code {
    private List<ApplicationUser>? _users;
    private List<ApplicationRole> _roles = new();
    private Dictionary<string, List<string>> _userRolesMap = new();

    private int _userMinPosition = 9999;
    private string _currentUserId = string.Empty;

    // Permissions
    private bool _canAssignRoles;
    private bool _canDeleteUsers;
    private bool _canEditAccountInfo;

    // Pagination & Filtering
    private string _searchTerm = string.Empty;
    private int _currentPage = 1;
    private int _pageSize = 10;
    private int _totalPages = 1;
    private int _totalUsers = 0;

    // Modals
    private bool _isEditing = false;
    private UserEditModel _model = new();
    private HashSet<string> _modelAssignedRoles = new();
    private string? _errorMessage;

    private bool _showDeleteConfirm = false;
    private ApplicationUser? _userToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissions();
        await LoadData();
    }

    private async Task LoadPermissions()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _currentUserId = UserManager.GetUserId(user) ?? string.Empty;

        _canAssignRoles = user.HasPermission(Permissions.AssignRoles);
        _canDeleteUsers = user.HasPermission(Permissions.DeleteUsers);
        _canEditAccountInfo = user.HasPermission(Permissions.EditAcountInfo);

        _roles = await RoleManager.Roles.ToListAsync();
        var currentUserRoles = user.FindAll(ClaimTypes.Role).Select(c => c.Value).ToList();

        _userMinPosition = _roles
            .Where(r => currentUserRoles.Contains(r.Name!))
            .Select(r => r.Position)
            .DefaultIfEmpty(9999)
            .Min();
    }

    private async Task ResetAndLoad()
    {
        _currentPage = 1;
        await LoadData();
    }

    private async Task ClearSearch()
    {
        _searchTerm = string.Empty;
        await ResetAndLoad();
    }

    private async Task ChangePage(int newPage)
    {
        if (newPage >= 1 && newPage <= _totalPages && newPage != _currentPage)
        {
            _currentPage = newPage;
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        var query = UserManager.Users.AsQueryable();

        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            var searchLower = _searchTerm.ToLower();
            query = query.Where(u =>
                (u.UserName != null && u.UserName.ToLower().Contains(searchLower)) ||
                (u.Email != null && u.Email.ToLower().Contains(searchLower)));
        }

        _totalUsers = await query.CountAsync();
        _totalPages = (int)Math.Ceiling(_totalUsers / (double)_pageSize);

        // Failsafe if deletion causes current page to be empty
        if (_currentPage > _totalPages && _totalPages > 0)
        {
            _currentPage = _totalPages;
        }

        _users = await query
            .OrderBy(u => u.UserName)
            .Skip((_currentPage - 1) * _pageSize)
            .Take(_pageSize)
            .ToListAsync();

        _userRolesMap.Clear();
        foreach (var user in _users)
        {
            var userRoles = await UserManager.GetRolesAsync(user);
            _userRolesMap[user.Id] = userRoles.ToList();
        }
    }
    private int GetMinPositionForRoles(IEnumerable<string> roleNames)
    {
        return _roles
            .Where(r => roleNames.Contains(r.Name!))
            .Select(r => r.Position)
            .DefaultIfEmpty(9999)
            .Min();
    }

    private async Task EditUser(ApplicationUser user, bool forceReadOnly)
    {
        _errorMessage = null;

        var targetRoles = _userRolesMap.GetValueOrDefault(user.Id) ?? new List<string>();
        _modelAssignedRoles = targetRoles.ToHashSet();

        _model = new UserEditModel
        {
            Id = user.Id,
            UserName = user.UserName ?? string.Empty,
            Email = user.Email ?? string.Empty,
            IsReadOnly = forceReadOnly || (!_canEditAccountInfo && !_canAssignRoles)
        };

        _isEditing = true;
    }

    private async Task SaveUser()
    {
        _errorMessage = null;
        var user = await UserManager.FindByIdAsync(_model.Id);

        if (user == null)
        {
            _errorMessage = "User not found.";
            return;
        }

        if (_canEditAccountInfo)
        {
            if (user.UserName != _model.UserName)
            {
                var setUsernameResult = await UserManager.SetUserNameAsync(user, _model.UserName);
                if (!setUsernameResult.Succeeded)
                {
                    _errorMessage = string.Join(", ", setUsernameResult.Errors.Select(e => e.Description));
                    return;
                }
            }

            if (user.Email != _model.Email)
            {
                var setEmailResult = await UserManager.SetEmailAsync(user, _model.Email);
                if (!setEmailResult.Succeeded)
                {
                    _errorMessage = string.Join(", ", setEmailResult.Errors.Select(e => e.Description));
                    return;
                }
            }

            if (!string.IsNullOrWhiteSpace(_model.NewPassword))
            {
                await UserManager.RemovePasswordAsync(user);
                var addPasswordResult = await UserManager.AddPasswordAsync(user, _model.NewPassword);
                if (!addPasswordResult.Succeeded)
                {
                    _errorMessage = string.Join(", ", addPasswordResult.Errors.Select(e => e.Description));
                    return;
                }
            }
        }

        if (_canAssignRoles)
        {
            var currentRoles = await UserManager.GetRolesAsync(user);

            var rolesToAdd = _modelAssignedRoles.Except(currentRoles).ToList();
            var rolesToRemove = currentRoles.Except(_modelAssignedRoles).ToList();

            rolesToAdd = rolesToAdd.Where(rName =>
                _roles.Any(r => r.Name == rName && r.Position > _userMinPosition && !r.IsBuiltIn)).ToList();

            rolesToRemove = rolesToRemove.Where(rName =>
                _roles.Any(r => r.Name == rName && r.Position > _userMinPosition && !r.IsBuiltIn)).ToList();

            if (rolesToAdd.Any())
            {
                await UserManager.AddToRolesAsync(user, rolesToAdd);
            }

            if (rolesToRemove.Any())
            {
                await UserManager.RemoveFromRolesAsync(user, rolesToRemove);
            }
        }

        _isEditing = false;
        await LoadData();
    }

    private void ToggleRole(string roleName, object? checkedValue)
    {
        if (checkedValue is null ? false : (bool)checkedValue)
        {
            _modelAssignedRoles.Add(roleName);
        }
        else
        {
            _modelAssignedRoles.Remove(roleName);
        }
    }

    private void ConfirmDelete(ApplicationUser user)
    {
        _userToDelete = user;
        _showDeleteConfirm = true;
    }

    private void CloseDeleteConfirm()
    {
        _showDeleteConfirm = false;
        _userToDelete = null;
    }

    private async Task DeleteConfirmed()
    {
        if (_userToDelete is not null && _canDeleteUsers)
        {
            var targetRoles = _userRolesMap.GetValueOrDefault(_userToDelete.Id) ?? new List<string>();
            var targetMinPos = GetMinPositionForRoles(targetRoles);

            // Double check server side
            if (targetMinPos > _userMinPosition && _userToDelete.Id != _currentUserId)
            {
                await UserManager.DeleteAsync(_userToDelete);
            }
        }

        CloseDeleteConfirm();
        await LoadData();
    }

    RenderFragment<List<string>> RenderUserRoles => roles => __builder =>
    {
        if (roles.Any())
        {
            <div class="d-flex flex-wrap gap-1 align-items-center">
                @foreach (var roleName in roles)
                {
                    var roleInfo = _roles.FirstOrDefault(r => r.Name == roleName);
                    if (roleInfo != null)
                    {
                        <span class="badge badge-subtle fw-normal"
                              style="border-left: 3px solid @roleInfo.Color !important;">
                            @roleInfo.Name
                        </span>
                    }
                }
            </div>
        }
        else
        {
            <span class="text-muted small"><em>No roles</em></span>
        }
    };

    RenderFragment<(ApplicationUser, bool)> RenderActions => item => __builder =>
    {
        var (user, isProtected) = item;
        var canManage = (_canEditAccountInfo || _canAssignRoles) && !isProtected;

        <button class="btn btn-sm @(canManage ? "btn-outline-primary" : "btn-outline-secondary")"
                @onclick="() => EditUser(user, !canManage)">
            @(canManage ? "Edit" : "View")
        </button>

        @if (_canDeleteUsers && !isProtected)
        {
            <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => ConfirmDelete(user)">
                Delete
            </button>
        }
    };

    public class UserEditModel
    {
        public string Id { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string NewPassword { get; set; } = string.Empty;
        public bool IsReadOnly { get; set; }
    }
}

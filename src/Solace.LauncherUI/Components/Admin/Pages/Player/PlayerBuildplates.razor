@page "/Admin/Players/{PlayerId}/Buildplates"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using System.Diagnostics
@using Serilog
@using Solace.BuildplateImporter
@using Solace.BuildplateRenderer
@using Solace.DB
@using Solace.EventBus.Client
@using Solace.LauncherUI.Programs
@using Solace.LauncherUI.Utils
@using Solace.ObjectStore.Client
@attribute [Authorize(Policy = Permissions.ManagePlayers)]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject ServerManager ServerManager

<PageTitle>Player Buildplates - Apace</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
    <a href="/Admin/Players" class="btn btn-link p-0 mb-2">
        ← Back to Players
    </a>
    <div class="d-flex align-items-baseline gap-2">
        <div class="section-title mb-0" style="border-bottom: none; padding-bottom: 0;">
            <img class="nav-icon" src="/images/buildplate_icon.png" alt="" />
            Buildplates for @(string.IsNullOrEmpty(_username) ? $"player {PlayerId}" : $"{_username} (ID: {PlayerId})")
        </div>
    </div>

    <button class="btn btn-primary" @onclick="OpenAddModal">
        + Add Buildplate
    </button>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger mb-4" role="alert">
        <strong>Error:</strong> @_errorMessage
        <button type="button" class="btn-close" style="float: right;" @onclick="() => _errorMessage = null" aria-label="Close"></button>
    </div>
}

@if (_playerBuildplates is not null && _playerBuildplates.Any())
{
    <div class="row mb-4">
        <div class="col-12 col-md-6 col-lg-4">
            <div class="input-group">
                <span class="input-group-text">⌕</span>
                <input type="text" class="form-control" placeholder="Search player buildplates..."
                       value="@_playerSearchTerm" @oninput="HandlePlayerSearch" />
            </div>
        </div>
    </div>
}

<div class="row g-4">
    @if (_playerBuildplates is null)
    {
        <div class="col-12">
            <div class="alert alert-info">
                Loading player buildplates...
            </div>
        </div>
    }
    else if (!_playerBuildplates.Any())
    {
        <div class="col-12">
            <div class="alert alert-info">
                This player doesn't have any buildplates yet.
            </div>
        </div>
    }
    else if (!FilteredPlayerBuildplates.Any())
    {
        <div class="col-12">
            <div class="alert alert-warning">
                No buildplates match your search criteria.
            </div>
        </div>
    }
    else
    {
        @foreach (var bp in PaginatedPlayerBuildplates)
        {
            float scaleVal = 1f / bp.BlocksPerMeter;
            string displayScale = scaleVal >= 1
                ? $"1:{scaleVal:0.##}"
                : $"{(1 / scaleVal):0.##}:1";

            <div class="col-12 col-md-6 col-lg-4 col-xl-3" @key="@bp.Id">
                <div class="card h-100 @(bp.IsBusy ? "opacity-50" : "")">
                    <BuildplatePreview BuildplateId="@bp.Id" IsTemplate=false PlayerId="@PlayerId" Size="@bp.Size"
                                       BlocksPerMeter="@bp.BlocksPerMeter" IsNight="@bp.IsNight"
                                       ResourcePackManager="@_resourcePackManager" />

                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(bp.ErrorMessage))
                        {
                            <div class="alert alert-danger py-2 small" role="alert">
                                ⚠ @bp.ErrorMessage
                                <button type="button" class="btn-close" style="float: right;"
                                        @onclick="() => bp.ErrorMessage = null"></button>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label visually-hidden">Buildplate Name</label>
                            <input type="text" minlength="1" maxlength="100" class="form-control fw-bold"
                                   @bind="bp.Name" @bind:event="oninput"
                                   disabled="@(!HasPermission(Permissions.ManagePlayers) || bp.IsBusy)" />
                        </div>

                        <div class="row text-muted small">
                            <div class="col-6 mb-2">
                                <span class="d-block fw-bold text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">Size</span>
                                <span>@(bp.Size)x@(bp.Size)</span>
                            </div>
                            <div class="col-6 mb-2">
                                <span class="d-block fw-bold text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">BPM</span>
                                <input type="number" min="1" max="100"
                                       class="form-control" style="padding: 4px 8px;" @bind="bp.BlocksPerMeter"
                                       @bind:event="oninput"
                                       disabled="@(!HasPermission(Permissions.ManagePlayers) || bp.IsBusy)" />
                            </div>
                        </div>
                    </div>
                    <div class="card-footer d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => OpenRemoveBuildplateModal(bp.Id)"
                                    disabled="@bp.IsBusy">
                                Remove
                            </button>

                            @if (bp.IsDirty || bp.IsSaving)
                            {
                                <button class="btn btn-success btn-sm" @onclick="() => SaveBuildplate(bp)"
                                        disabled="@bp.IsBusy">
                                    @if (bp.IsSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span>
                                    }
                                    Save
                                </button>
                            }
                        </div>

                        <button class="btn btn-outline btn-sm w-100" @onclick="() => RegeneratePreview(bp)"
                                disabled="@bp.IsBusy">
                            @if (bp.IsRegeneratingPreview)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                                <span>Regenerating...</span>
                            }
                            else
                            {
                                <img class="nav-icon" src="/images/settings_icon.png" alt="" />
                                <span>Regenerate In-Game Preview</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (TotalPlayerPages > 1)
{
    <nav aria-label="Player buildplates pagination" class="mt-4 d-flex justify-content-center">
        <ul class="pagination mb-0" style="display: flex; gap: 6px; list-style: none;">
            <li class="page-item @(_playerCurrentPage <= 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePlayerPage(_playerCurrentPage - 1)">
                    « Prev
                </button>
            </li>
            <li class="page-item disabled">
                <span class="page-link">
                    Page @_playerCurrentPage of @TotalPlayerPages
                </span>
            </li>
            <li class="page-item @(_playerCurrentPage >= TotalPlayerPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => ChangePlayerPage(_playerCurrentPage + 1)">
                    Next »
                </button>
            </li>
        </ul>
    </nav>
}

@if (_showAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.65); position: fixed; inset: 0; z-index: 1050;">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="margin: 5vh auto;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select Template Buildplate</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <div class="modal-body" style="padding: 20px; background: rgba(0,0,0,0.15);">
                    <div class="input-group mb-4">
                        <span class="input-group-text">⌕</span>
                        <input type="text" class="form-control" placeholder="Search templates by name..."
                               @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyUp" />
                        <button class="btn btn-primary" type="button" @onclick="PerformSearch">Search</button>
                    </div>

                    @if (_isLoadingTemplates || _templates is null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border" role="status"></div>
                            <div class="mt-2 text-muted">Loading templates...</div>
                        </div>
                    }
                    else if (!_templates.Any())
                    {
                        <div class="alert alert-warning">
                            No template buildplates found matching your search criteria.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var template in _templates)
                            {
                                <div class="col-12 col-md-6 col-lg-4" @key="template.Id">
                                    <div class="card h-100 @(template.IsAdding ? "opacity-75" : "")">
                                        <div class="position-relative" style="aspect-ratio: 16 / 9; overflow: visible;">
                                            <BuildplatePreview BuildplateId="@template.Id" IsTemplate=true Size="@template.Size"
                                                               BlocksPerMeter="@template.BlocksPerMeter" IsNight="@template.IsNight"
                                                               ResourcePackManager="@_resourcePackManager" />
                                        </div>
                                        <div class="card-body p-3 d-flex flex-column">
                                            <h6 class="mb-1 fw-bold text-truncate" title="@template.Name">@template.Name</h6>

                                            @if (!string.IsNullOrEmpty(template.ErrorMessage))
                                            {
                                                <div
                                                    class="alert alert-danger py-1 px-2 small d-flex justify-content-between align-items-center mb-2">
                                                    <span>✕ @template.ErrorMessage</span>
                                                    <button type="button" class="btn-close" style="font-size: 0.5rem"
                                                            @onclick="() => template.ErrorMessage = null"></button>
                                                </div>
                                            }

                                            @if (!string.IsNullOrEmpty(template.SuccessMessage))
                                            {
                                                <div class="alert alert-success py-1 px-2 small mb-2">
                                                    ✓ @template.SuccessMessage
                                                </div>
                                            }

                                            <small class="text-muted mb-3 d-block">
                                                Size: @(template.Size)x@(template.Size) | BPM: @template.BlocksPerMeter
                                            </small>

                                            <button class="btn btn-sm btn-success mt-auto"
                                                    @onclick="async () => await AddBuildplateFromTemplate(template)"
                                                    disabled="@template.IsAdding">
                                                @if (template.IsAdding)
                                                {
                                                    <span class="spinner-border spinner-border-sm" role="status"
                                                          aria-hidden="true"></span>
                                                    <span>Adding...</span>
                                                }
                                                else
                                                {
                                                    <span>+ Add</span>
                                                }
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer d-flex justify-content-between align-items-center">
                    <div>
                        @if (TotalPages > 1)
                        {
                            <nav aria-label="Template search pagination">
                                <ul class="pagination pagination-sm mb-0" style="display: flex; gap: 4px; list-style: none;">
                                    <li class="page-item @(_currentPage <= 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(_currentPage - 1)">«
                                            Prev
                                        </button>
                                    </li>
                                    <li class="page-item disabled">
                                        <span class="page-link">Page @_currentPage of
                                            @TotalPages
                                        </span>
                                    </li>
                                    <li class="page-item @(_currentPage >= TotalPages ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(_currentPage + 1)">
                                            Next»
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddModal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.65); position: fixed; inset: 0; z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 480px; margin: 10vh auto;">
            <div class="modal-content" style="border-color: #6a2a2a;">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">⚠ Confirm Removal</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body py-4 text-center" style="padding: 20px;">
                    <p class="mb-1">Are you sure you want to remove this buildplate from the player?</p>
                    <strong style="font-size: 1.1rem; color: #8bc34a;">@_nameToDelete</strong>
                    <div class="text-muted small mt-2">This action cannot be undone.</div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Remove Buildplate</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public required string PlayerId { get; set; }

    private ClaimsPrincipal? _user;
    private string? _username;

    private ResourcePackManager _resourcePackManager = null!;

    // State
    private List<PlayerBuildplate>? _playerBuildplates;
    private List<TemplateDto>? _templates;
    private bool _showAddModal = false;
    private string? _errorMessage;

    private string _playerSearchTerm = "";
    private int _playerCurrentPage = 1;
    private int _playerPageSize = 8;

    private IEnumerable<PlayerBuildplate> FilteredPlayerBuildplates
        => _playerBuildplates?.Where(bp => string.IsNullOrWhiteSpace(_playerSearchTerm) || bp.Name.Contains(_playerSearchTerm,
StringComparison.OrdinalIgnoreCase))
        ?? Array.Empty<PlayerBuildplate>();

    private int TotalPlayerPages => Math.Max(1, (int)Math.Ceiling((double)FilteredPlayerBuildplates.Count() /
_playerPageSize));

    private IEnumerable<PlayerBuildplate> PaginatedPlayerBuildplates =>
        FilteredPlayerBuildplates.Skip((_playerCurrentPage - 1) * _playerPageSize).Take(_playerPageSize);

    private void HandlePlayerSearch(ChangeEventArgs e)
    {
        _playerSearchTerm = e.Value?.ToString() ?? "";
        _playerCurrentPage = 1; // Reset to page 1 on new search
    }

    private void ChangePlayerPage(int newPage)
    {
        if (newPage >= 1 && newPage <= TotalPlayerPages)
        {
            _playerCurrentPage = newPage;
        }
    }

    // Search and Pagination State for Templates
    private string? _searchTerm = "";
    private int _currentPage = 1;
    private int _pageSize = 6;
    private int _totalCount = 0;
    private bool _isLoadingTemplates = false;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)_totalCount / _pageSize));

    // State for Deletion
    private bool _showDeleteModal = false;
    private string? _idToDelete;
    private string? _nameToDelete;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        _resourcePackManager = await ResourcePackManagerSingleton.GetResourcePackManagerAsync();

        try
        {
            using var liveDb = DataUtils.OpenLiveDB(Settings.Instance);
            if (liveDb is not null)
            {
                _username = await DataUtils.GetUsername(PlayerId, liveDb);
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to get username for player '{PlayerId}': {ex}");
        }

        await LoadPlayerBuildplates();
        await LoadBuildplateTemplates(); // Load initial page
    }

    private async Task LoadPlayerBuildplates()
    {
        _errorMessage = null; // Clear previous errors

        DB.Models.Player.Buildplates buildplatesModel;
        try
        {
            using var earthDB = EarthDB.Open(Settings.Instance.EarthDatabaseConnectionString ?? "");

            EarthDB.Results results = await new EarthDB.Query(false)
                .Get("buildplates", PlayerId, typeof(DB.Models.Player.Buildplates))
                .ExecuteAsync(earthDB, default);
            buildplatesModel = results.Get<DB.Models.Player.Buildplates>("buildplates");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to load buildplates for player '{PlayerId}': {ex}");
            _errorMessage = "Could not load buildplates. Please check the database connection.";
            _playerBuildplates = new();
            return;
        }

        _playerBuildplates = new(buildplatesModel._buildplates.Count);
        foreach (var (buildplateId, buildplate) in buildplatesModel._buildplates)
        {
            var bp = new PlayerBuildplate()
            {
                Id = buildplateId,
                Name = buildplate.Name,
                Size = buildplate.Size,
                BlocksPerMeter = buildplate.Scale,
                IsNight = buildplate.Night,
                ServerDataObjectId = buildplate.ServerDataObjectId,
                PreviewObjectId = buildplate.PreviewObjectId,
            };

            bp.AcceptChanges();
            _playerBuildplates.Add(bp);
        }
    }

    private async Task PerformSearch()
    {
        _currentPage = 1;
        await LoadBuildplateTemplates();
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key is "Enter")
        {
            await PerformSearch();
        }
    }

    private async Task ChangePage(int newPage)
    {
        if (newPage < 1 || newPage > TotalPages)
        {
            return;
        }
        
        _currentPage = newPage;
        await LoadBuildplateTemplates();
    }

    private async Task LoadBuildplateTemplates()
    {
        _isLoadingTemplates = true;
        
        StateHasChanged();

        try
        {
            using var earthDB = EarthDB.Open(Settings.Instance.EarthDatabaseConnectionString ?? "");

            int skip = (_currentPage - 1) * _pageSize;
            string? searchFilter = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm;

            var results = await new EarthDB.ObjectQuery(false)
                .SearchBuildplates(out var searchArguments, true, true, skip: skip, take: _pageSize, name: searchFilter?.Trim())
                .ExecuteAsync(earthDB, default);

            var (buildplates, buildplatesCount, totalCount) = results.GetBuildplates(searchArguments);

            Debug.Assert(totalCount is not null);
            _totalCount = totalCount.Value;
            _templates = new List<TemplateDto>();

            foreach (var (id, dbBp) in buildplates)
            {
                if (dbBp is not null)
                {
                    _templates.Add(new TemplateDto
                    {
                        Id = id,
                        Name = dbBp.Name,
                        Size = dbBp.Size,
                        BlocksPerMeter = dbBp.Scale,
                        IsNight = dbBp.Night,
                        ServerDataObjectId = dbBp.ServerDataObjectId,
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Could not load templates for player assignment: {ex}");
            _templates = new List<TemplateDto>();
            _totalCount = 0;
        }
        finally
        {
            _isLoadingTemplates = false;
            StateHasChanged(); // Ensure loading spinner is removed
        }
    }

    private void OpenAddModal()
        => _showAddModal = true;

    private void CloseAddModal()
        => _showAddModal = false;

    private async Task AddBuildplateFromTemplate(TemplateDto template)
    {
        if (_playerBuildplates is null || template.IsAdding)
        {
            return;
        }

        template.IsAdding = true;
        template.ErrorMessage = null;
        template.SuccessMessage = null;
        StateHasChanged();

        if (!await ServerManager.EnsureComponentsOnline(EventBusServer.ExeName, ObjectStoreServer.ExeName,
BuildplateLauncher.ExeName))
        {
            template.ErrorMessage = "The server must be running.";
            template.IsAdding = false;
            return;
        }

        try
        {
            await using var importer = await Importer.CreateFromSettings(Settings.Instance, Log.Logger);

            var buildplateId = await importer.AddBuidplateToPlayer(template.Id, PlayerId, default);
            if (buildplateId is null)
            {
                template.ErrorMessage = $"The importer failed to add template '{template.Name}' to the player.";
                return;
            }

            var buildplates = (await new EarthDB.Query(true)
                .Get("buildplates", PlayerId, typeof(DB.Models.Player.Buildplates))
                .ExecuteAsync(importer.EarthDB))
                .Get<DB.Models.Player.Buildplates>("buildplates");

            var dbBuildplate = buildplates.GetBuildplate(buildplateId)!;

            var buildplate = new PlayerBuildplate
            {
                Id = buildplateId,
                Name = template.Name,
                Size = template.Size,
                BlocksPerMeter = template.BlocksPerMeter,
                IsNight = template.IsNight,
                ServerDataObjectId = dbBuildplate.ServerDataObjectId,
                PreviewObjectId = dbBuildplate.PreviewObjectId,
            };

            buildplate.AcceptChanges();

            _playerBuildplates.Add(buildplate);

            template.SuccessMessage = "Added successfully!";
            
            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                template.SuccessMessage = null;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to add buildplate '{template.Id}' to player '{PlayerId}': {ex}");
            template.ErrorMessage = $"An error occurred while importing the buildplate: {ex.Message}";
        }
        finally
        {
            template.IsAdding = false;
            StateHasChanged();
        }
    }

    private async Task OpenRemoveBuildplateModal(string id)
    {
        _errorMessage = null;

        var item = _playerBuildplates?.FirstOrDefault(x => x.Id == id);
        if (item is not null)
        {
            if (!await ServerManager.EnsureComponentsOnline(ObjectStoreServer.ExeName))
            {
                _errorMessage = "The server must be running.";
                return;
            }

            _idToDelete = id;
            _nameToDelete = item.Name;
            _showDeleteModal = true;
        }
    }

    private async Task ConfirmDelete()
    {
        if (_idToDelete != null && _playerBuildplates != null)
        {
            var item = _playerBuildplates.FirstOrDefault(x => x.Id == _idToDelete);
            if (item is not null)
            {
                try
                {
                    if (await RemoveBuildplate(_idToDelete))
                    {
                        _playerBuildplates.Remove(item);
                        
                        // Handle edge case where deleting leaves the current page empty
                        if (_playerCurrentPage > TotalPlayerPages)
                        {
                            _playerCurrentPage = TotalPlayerPages;
                        }
                    }
                    else
                    {
                        _errorMessage = $"An error occurred while removing the buildplate.";
                    }
                }
                catch (Exception ex)
                {
                    Log.Error($"Failed to remove buildplate '{_idToDelete}' from player '{PlayerId}': {ex}");
                    _errorMessage = $"An error occurred while removing the buildplate: {ex.Message}";
                }
            }
        }

        CloseDeleteModal();
    }

    private async Task<bool> RemoveBuildplate(string id)
    {
        await using var importer = await Importer.CreateFromSettings(Settings.Instance, Log.Logger);

        return await importer.RemoveBuildplateFromPlayer(id, PlayerId, default);
    }

    private void CloseDeleteModal()
    {
        _showDeleteModal = false;
        _idToDelete = null;
        _nameToDelete = null;
    }

    private async Task SaveBuildplate(PlayerBuildplate bp)
    {
        if (!HasPermission(Permissions.ManagePlayers))
        {
            return;
        }

        bp.IsSaving = true;
        bp.ErrorMessage = null;
        bp.Name = bp.Name.Trim();

        if (string.IsNullOrEmpty(bp.Name))
        {
            bp.ErrorMessage = "Name cannot be empty.";
            bp.IsSaving = false;
            return;
        }

        try
        {
            using var earthDB = EarthDB.Open(Settings.Instance.EarthDatabaseConnectionString ?? "");

            var results = await new EarthDB.Query(false)
                .Get("buildplates", PlayerId, typeof(DB.Models.Player.Buildplates))
                .ExecuteAsync(earthDB, default);
            var playerBuildplates = results.Get<DB.Models.Player.Buildplates>("buildplates");

            if (playerBuildplates._buildplates.TryGetValue(bp.Id, out var dbBuildplate))
            {
                dbBuildplate = dbBuildplate with { Name = bp.Name, Scale = bp.BlocksPerMeter, };
                playerBuildplates.AddBuildplate(bp.Id, dbBuildplate);

                await new EarthDB.Query(true)
                    .Update("buildplates", PlayerId, playerBuildplates)
                    .ExecuteAsync(earthDB, default);

                await Task.Delay(250);
                
                bp.AcceptChanges();
                Log.Information($"Successfully updated buildplate {bp.Id} for player {PlayerId}");
            }
            else
            {
                bp.ErrorMessage = "Buildplate not found in database.";
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to save buildplate '{bp.Id}' for player '{PlayerId}': {ex}");
            bp.ErrorMessage = "Failed to save. Try again?";
        }
        finally
        {
            bp.IsSaving = false;
        }
    }

    private async Task RegeneratePreview(PlayerBuildplate bp)
    {
        if (!HasPermission(Permissions.ManagePlayers))
        {
            return;
        }

        bp.IsRegeneratingPreview = true;
        bp.ErrorMessage = null;

        if (!await ServerManager.EnsureComponentsOnline(EventBusServer.ExeName, ObjectStoreServer.ExeName,
BuildplateLauncher.ExeName))
        {
            bp.ErrorMessage = "The server must be running.";
            bp.IsRegeneratingPreview = false;
            return;
        }

        try
        {
            await using var importer = await Importer.CreateFromSettings(Settings.Instance, Log.Logger);

            if (!await importer.RegeneratePlayerBuildplatePreviewAsync(PlayerId, bp.Id, default))
            {
                bp.ErrorMessage = "Failed to regenerate preview, check Launcher logs for details.";
                return;
            }

            var buildplates = (await new EarthDB.Query(true)
                .Get("buildplates", PlayerId, typeof(DB.Models.Player.Buildplates))
                .ExecuteAsync(importer.EarthDB))
                .Get<DB.Models.Player.Buildplates>("buildplates");

            var buildplate = buildplates.GetBuildplate(bp.Id)!;

            bp.ServerDataObjectId = buildplate.ServerDataObjectId;

            Log.Information($"Successfully regenerated preview for player buildplate {bp.Id}");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to regenerate preview for player buildplate '{bp.Id}': {ex}");
            bp.ErrorMessage = "Failed to regenerate preview. Try again?";
        }
        finally
        {
            bp.IsRegeneratingPreview = false;
        }
    }

    private bool HasPermission(string permission)
        => _user?.HasPermission(permission) ?? false;

    public class PlayerBuildplate
    {
        public required string Id { get; set; }
        public required string Name { get; set; }
        public int Size { get; set; }
        public int BlocksPerMeter { get; set; }
        public bool IsNight { get; set; }

        public required string ServerDataObjectId { get; set; }
        public required string PreviewObjectId { get; set; }

        // Change Tracking
        private string? _originalName;
        private int _originalBlocksPerMeter = -1;

        public bool IsDirty => Name != _originalName || BlocksPerMeter != _originalBlocksPerMeter;

        // UI State
        public bool IsSaving { get; set; }
        public bool IsRegeneratingPreview { get; set; }
        public bool IsBusy => IsSaving || IsRegeneratingPreview;
        public string? ErrorMessage { get; set; }

        public void AcceptChanges()
        {
            _originalName = Name;
            _originalBlocksPerMeter = BlocksPerMeter;
        }
    }

    public class TemplateDto
    {
        public required string Id { get; set; }
        public required string Name { get; set; }
        public int Size { get; set; }
        public int BlocksPerMeter { get; set; }
        public bool IsNight { get; set; }
        
        public required string ServerDataObjectId { get; set; }
        
        public bool IsAdding { get; set; }
        public string? ErrorMessage { get; set; }
        public string? SuccessMessage { get; set; }
    }

@page "/About"

<PageTitle>About - Apace</PageTitle>

<div class="d-flex justify-content-center">
    <div class="text-center" style="max-width: 640px;">

        <h1 class="display-4 mb-3">Apace</h1>
        <p class="lead mb-4">
            A super-fast replacement server software for <strong style="color:#8bc34a;">Minecraft Earth™</strong>.
        </p>

        <hr class="my-5" />

        <div class="card mb-5 text-start">
            <div class="card-body p-4">
                <h3 style="font-size: 1rem; color: #81c784;">Project Origins</h3>
                <p class="text-muted">
                    Based on the original <a href="https://github.com/Earth-Restored/Solace" target="_blank">Solace</a> project.
                </p>
                <p>
                    Developed by <a href="https://github.com/KotPasztet" target="_blank" class="fw-bold">KotPasztet</a>.
                </p>

                <div class="mt-4 text-center">
                    <a href="https://github.com/KotPasztet/Apace/issues/new/choose" target="_blank"
                       class="btn btn-outline-danger">
                        🐞 Report Bug / Request Feature
                    </a>
                </div>
            </div>
        </div>

        <div class="alert alert-secondary small text-start" role="alert">

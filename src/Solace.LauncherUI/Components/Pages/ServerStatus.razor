@page "/ServerStatus"
@rendermode InteractiveServer
@using System.Security.Claims
@using Solace.LauncherUI.Utils
@inject AuthenticationStateProvider AuthStateProvider
@inject LogsLogService LogService
@inject ServerManager ServerManager
@inject IJSRuntime JS

<PageTitle>Server Status - Apace</PageTitle>

<script>
    window.initLogScroller = (container) => {
        if (!container) return;

        container.scrollTop = container.scrollHeight;

        let isScrolledToBottom = true;

        container.addEventListener('scroll', () => {
            isScrolledToBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 10;
        });

        const observer = new MutationObserver(() => {
            if (isScrolledToBottom) {
                container.scrollTop = container.scrollHeight;
            }
        });

        observer.observe(container, { childList: true, subtree: true });
    };
</script>

<div class="card mb-4">
    <div class="card-body text-center">
        <h6 class="text-muted text-uppercase mb-2" style="font-size: 0.7rem; letter-spacing: 2px;">System Status</h6>
        <div class="d-flex align-items-center justify-content-center mt-2">
            <div class="status-dot @GetStatusClass(_currentStatus) mr-2"></div>
            <h2 class="display-4 mb-0" style="font-size: 1.8rem; border-bottom: none; padding-bottom: 0;">@_currentStatus.ToString().ToUpper()</h2>
        </div>
        <small class="text-muted mt-3 d-block">Last updated: @DateTime.Now.ToString("t")</small>
    </div>
</div>

@if (_eulaPending)
{
    <div class="alert alert-warning">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <strong>Mojang EULA must be accepted</strong><br />
                <small>The Minecraft server requires you to accept the End User License Agreement.</small>
            </div>
            <button class="btn btn-warning btn-sm" @onclick="AcceptEula">
                ✓ Accept EULA
            </button>
        </div>
    </div>
}

<div class="section-title">Components</div>
<div class="comp-grid mb-4">
    @foreach (var comp in ServerManager.Components)
    {
        <div class="comp-card">
            <div class="comp-info">
                <div class="status-dot @GetStatusClass(comp.Status)"></div>
                <div>
                    <div class="comp-name">@comp.Name</div>
                    <div class="comp-status">@comp.Status.ToString()</div>
                </div>
            </div>

            @if (comp.Status is LauncherUI.ServerStatus.Offline)
            {
                <button class="btn btn-success btn-sm" style="width: 34px; height: 34px; padding: 0; justify-content: center;"
                        title="Start Component"
                        disabled="@(IsButtonDisabled(Permissions.StartServer) || !ServerManager.CanStart || _currentStatus is LauncherUI.ServerStatus.Starting or LauncherUI.ServerStatus.Stopping)"
                        @onclick="() => StartComponent(comp.ExeName)">
                    ▶
                </button>
            }
        </div>
    }
</div>

@if (!IsButtonDisabled(Permissions.StartServer) || !IsButtonDisabled(Permissions.RestartServer) ||
    !IsButtonDisabled(Permissions.StopServer))
{
    <div class="section-title mt-4">Controls</div>
    <div class="row gap-2 mb-4">
        <div class="col">
            <button class="btn btn-success btn-lg w-100 d-flex flex-column align-items-center justify-content-center"
                    disabled="@(IsButtonDisabled(Permissions.StartServer) || !ServerManager.CanStart)"
                    @onclick="() => StartServer()">
                <span style="font-size: 1.5rem;">▶</span>
                <span style="font-size: 0.8rem;">Start All</span>
            </button>
        </div>
        <div class="col">
            <button class="btn btn-warning btn-lg w-100 d-flex flex-column align-items-center justify-content-center"
                    disabled="@(IsButtonDisabled(Permissions.RestartServer) || !ServerManager.CanRestart)"
                    @onclick="() => RestartServer()">
                <span style="font-size: 1.5rem; font-weight: 900; line-height: 1;">↺</span>
                <span style="font-size: 0.8rem; font-weight: 700;">Restart</span>
            </button>
        </div>
        <div class="col">
            <button class="btn btn-danger btn-lg w-100 d-flex flex-column align-items-center justify-content-center"
                    disabled="@(IsButtonDisabled(Permissions.StopServer) || !ServerManager.CanStop)"
                    @onclick="() => StopServer()">
                <span style="font-size: 1.5rem;">■</span>
                <span style="font-size: 0.8rem;">Stop</span>
            </button>
        </div>
        <div class="col-12 mt-2">
            <button class="btn btn-outline-danger btn-lg w-100 d-flex flex-column align-items-center justify-content-center"
                    disabled="@IsButtonDisabled(Permissions.StopServer)" @onclick="() => KillAll()">
                <span style="font-size: 1.5rem; font-weight: 900;">✕</span>
                <span style="font-size: 0.8rem; font-weight: bold;">KILL ALL PROCESSES</span>
            </button>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">▸ Live Logs</div>
    <div class="card-body">
        @if (HasPermission(Permissions.ViewServerLogs))
        {
            <div class="nav-pills mb-3" style="overflow-x: auto;">
                @foreach (var component in LogService.GetKnownComponents())
                {
                    <button class="@(_activeTab == component ? "active" : "")"
                            @onclick="() => _activeTab = component">
                        @component
                    </button>
                }
            </div>

            <div class="log-terminal" @ref="_logContainerRef">
                <div class="log-content">
                    @foreach (var log in LogService.GetLogsFor(_activeTab))
                    {
                        <div class="log-line"><span class="log-time">[@log.Timestamp.ToString("HH:mm:ss")]</span> <span class="log-level @GetLogLevelClass(log.Level)">[@GetShortLevel(log.Level)]</span> <span class="log-msg">@log.RenderedMessage</span></div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-light text-center py-4">
                <span style="font-size: 1.5rem;" class="d-block mb-2">🔒</span>
                <span class="text-muted">Log access restricted</span>
            </div>
        }
    </div>
</div>

@code {
    private Solace.LauncherUI.ServerStatus _currentStatus => ServerManager.Status;

    private string _activeTab = "Launcher";
    private ClaimsPrincipal? _user;
    private ElementReference _logContainerRef;
    private bool _scrollerInitialized;
    private bool _eulaPending;
    private Timer? _eulaCheckTimer;
    private Timer? _statusRefreshTimer;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        LogService.OnLogReceived += HandleUpdate;
        ServerManager.OnStatusChanged += HandleUpdate;

        // Poll EULA status every 2 seconds during server startup
        _eulaCheckTimer = new Timer(async _ =>
        {
            var pending = Solace.LauncherUI.FileChecker.EulaPending;
            if (_eulaPending != pending)
            {
                _eulaPending = pending;
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(2));

        // Refresh component statuses every 3s (BuildplateLauncher Starting → Online)
        _statusRefreshTimer = new Timer(async _ =>
        {
            ServerManager.RefreshComponentStatuses();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (HasPermission(Permissions.ViewServerLogs) && !_scrollerInitialized)
        {
            await JS.InvokeVoidAsync("initLogScroller", _logContainerRef);
            _scrollerInitialized = true;
        }
    }

    private async void HandleUpdate()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LogService.OnLogReceived -= HandleUpdate;
        ServerManager.OnStatusChanged -= HandleUpdate;
        _eulaCheckTimer?.Dispose();
        _statusRefreshTimer?.Dispose();
    }

    private async Task StartServer()
        => await ServerManager.Start();

    private async Task StopServer()
        => await ServerManager.Stop();

    private async Task RestartServer()
        => await ServerManager.Restart();

    private async Task KillAll()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to force kill all server processes?");

        if (confirmed)
        {
            await ServerManager.KillAll();
        }
    }

    private void AcceptEula()
    {
        FileChecker.AcceptEula();
        _eulaPending = false;
    }

    private async Task StartComponent(string exeName)
        => await ServerManager.EnsureComponentsOnline(exeName);

    private bool HasPermission(string permission)
        => _user?.HasPermission(permission) ?? false;

    private bool IsButtonDisabled(string permission)
        => !HasPermission(permission);

    private string GetStatusClass(Solace.LauncherUI.ServerStatus status)
        => status switch
        {
            Solace.LauncherUI.ServerStatus.Online => "status-online",
            Solace.LauncherUI.ServerStatus.PartiallyOnline => "status-online",
            Solace.LauncherUI.ServerStatus.Starting => "status-starting",
            Solace.LauncherUI.ServerStatus.Stopping => "status-stopping",
            _ => "status-offline"
        };

    private string GetShortLevel(string? level)
        => level switch
        {
            "Verbose" => "VRB",
            "Debug" => "DBG",
            "Information" => "INF",
            "Warning" => "WRN",
            "Error" => "ERR",
            "Fatal" => "FTL",
            _ => level?.Length >= 3 ? level.Substring(0, 3).ToUpperInvariant() : "UNK"
        };

    private string GetLogLevelClass(string? level)
        => level switch
        {
            "Verbose" => "log-vrb",
            "Debug" => "log-dbg",
            "Information" => "log-inf",
            "Warning" => "log-wrn",
            "Error" => "log-err",
            "Fatal" => "log-ftl",
            _ => ""
        };
}

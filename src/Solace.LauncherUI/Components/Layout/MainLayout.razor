@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="topbar">
            <button class="theme-btn" onclick="toggleDarkMode()" title="Toggle dark mode">
                <span class="dmb-moon">☀ LIGHT</span>
                <span class="dmb-sun">🌙 DARK</span>
            </button>
            <a href="/About" class="topbar-link">About</a>
        </div>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
